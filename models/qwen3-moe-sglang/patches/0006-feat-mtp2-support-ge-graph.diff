+    def prepare_forward_batch(self, bs: int, num_seqs: int) -> ForwardBatch:
+        num_tokens = bs * self.num_tokens_per_bs
+
+        # Graph inputs
+        input_ids = self.input_ids[:num_tokens]
+        req_pool_indices = self.req_pool_indices[:num_seqs]
+        seq_lens = self.seq_lens[:num_seqs]
+        seq_lens.fill_(self.num_tokens_per_bs)
+        seq_lens_cpu = self.seq_lens_cpu[:num_seqs]
+        extend_seq_lens = self.extend_seq_lens[:num_seqs]
+        extend_seq_lens_cpu = self.extend_seq_lens_cpu[:num_seqs]
+        out_cache_loc = self.out_cache_loc[: num_tokens]
+        positions = self.positions[:num_tokens]
+        mrope_positions = self.mrope_positions[:, :num_tokens]
+        topk_p = self.topk_p[:num_seqs]
+        topk_index = self.topk_index[:num_seqs]
+        hidden_states = self.hidden_states[:num_seqs]
+
+        if self.require_mlp_tp_gather:
+            global_num_tokens = torch.tensor(
+                    [
+                    num_tokens // self.dp_size + (i < (num_tokens % self.dp_size))
+                    for i in range(self.dp_size)
+                    ],
+                    dtype=torch.int64,
+                    device=self.input_ids.device,
+                )
+            self.global_num_tokens_for_logprob_gpu = torch.tensor(
+                    [
+                    num_tokens // self.dp_size + (i < (num_tokens % self.dp_size))
+                    for i in range(self.dp_size)
+                    ],
+                    dtype=torch.int64,
+                    device=self.input_ids.device,
+                )
+            global_dp_buffer_len = num_tokens * self.dp_size
+        elif self.require_attn_tp_gather:
+            global_num_tokens = torch.tensor(
+                    [num_tokens],
+                    dtype=torch.int64,
+                    device=self.input_ids.device,
+                )
+            self.global_num_tokens_for_logprob_gpu = torch.tensor(
+                    [num_tokens],
+                    dtype=torch.int64,
+                    device=self.input_ids.device,
+                )
+            global_dp_buffer_len = num_tokens
+        else:
+            global_num_tokens = None
+            global_dp_buffer_len = None
+
+        if self.perfect_eplb and hasattr(self.model_runner.model, "gen_cur_topk_idx"):
+            cur_topk_list = self.model_runner.model.gen_cur_topk_idx(num_tokens)
+        else:
+            cur_topk_list = None
+
+        spec_info = EagleDraftInput(
+            topk_p=topk_p,
+            topk_index=topk_index,
+            hidden_states=hidden_states,
+            capture_hidden_mode=CaptureHiddenMode.LAST,
+        )
+        spec_info.positions = None
+
+        # Forward batch
+        forward_batch = ForwardBatch(
+            forward_mode=ForwardMode.DECODE,
+            batch_size=num_seqs,
+            input_ids=input_ids,
+            req_pool_indices=req_pool_indices,
+            seq_lens=seq_lens,
+            seq_lens_cpu=seq_lens_cpu,
+            extend_seq_lens=extend_seq_lens,
+            extend_seq_lens_cpu=extend_seq_lens_cpu,
+            req_to_token_pool=self.model_runner.req_to_token_pool,
+            token_to_kv_pool=self.model_runner.token_to_kv_pool,
+            out_cache_loc=out_cache_loc,
+            seq_lens_sum=seq_lens.sum().item(),
+            return_logprob=False,
+            positions=positions,
+            perfect_eplb=self.perfect_eplb,
+            cur_topk_list=cur_topk_list,
+            mrope_positions=mrope_positions,
+            global_num_tokens_gpu=global_num_tokens,
+            dp_padding_mode=DpPaddingMode.get_default_mode_in_cuda_graph(),
+            global_dp_buffer_len=global_dp_buffer_len,
+            spec_algorithm=self.model_runner.spec_algorithm,
+            spec_info=spec_info,
+            capture_hidden_mode=(
+                spec_info.capture_hidden_mode if spec_info else CaptureHiddenMode.NULL
+            ),
+            global_num_tokens_for_logprob_gpu=self.global_num_tokens_for_logprob_gpu,
+        )
+        return forward_batch
+
+    def warm_up(self):
+        @torch.compile(dynamic=True, backend=get_compiler_backend())
+        def run_for_init(input):
+            return input + 1
+
+        input = torch.zeros([1]).to(self.model_runner.device)
+        run_for_init(input)
+
+        backend = get_compiler_backend()
+        if self.enable_cache_compile:
+            self.model_runner.model.compile_forward_draft = tng.inference.cache_compile(
+                self.model_runner.model.draft,
+                cache_dir=_GE_CACHE_DIR,
+                config=get_compiler_config(),
+                dynamic=False,
+                fullgraph=True,
+                ge_cache=True
+            )
+        else:
+            self.model_runner.model.compile_forward_draft = torch.compile(
+                torch.no_grad()(self.model_runner.model.forward),
+                fullgraph=True,
+                dynamic=False,
+                backend=backend,
+            )
+        self.model_runner.model.time_decorator_forward_draft = \
+            time_decorator(self.model_runner.model.compile_forward_draft)
+
+        compile_range = (
+            tqdm.tqdm(list(reversed(self.compile_bs)))
+            if get_tensor_model_parallel_rank() == 0
+            else reversed(self.compile_bs)
+        )
+
+        for bs in compile_range:
+            if get_tensor_model_parallel_rank() == 0:
+                avail_mem = get_available_gpu_memory(
+                    self.model_runner.device,
+                    self.model_runner.gpu_id,
+                    empty_cache=False,
+                )
+                compile_range.set_description(
+                    f"Capturing draft model batches ({bs=} {avail_mem=:.2f} GB)"
+                )
+            num_tokens = bs * self.num_tokens_per_bs
+            self.forward_batch[bs] = self.prepare_forward_batch(bs, num_tokens)
+
+            set_dp_buffer_len(self.forward_batch[bs].global_dp_buffer_len, num_tokens, dp_max_padding=True)
+            set_is_extend_in_batch(False)
+            self.model_runner.draft_attn_backend.init_forward_metadata(self.forward_batch[bs], can_run_graph=True)
+            self.forward_batch[bs].attn_backend = self.model_runner.draft_attn_backend.attn_backends[0]
+
+            # Run and compile
+            def run_once():
+                # Clean intermediate result cache for DP attention
+                self.forward_batch[bs].dp_local_start_pos = self.forward_batch[bs].dp_local_num_tokens = None
+
+                # Backup two fields, which will be modified in-place in `draft_forward`.
+                output_cache_loc_backup = self.forward_batch[bs].out_cache_loc
+                hidden_states_backup = self.forward_batch[bs].spec_info.hidden_states
+
+                with torch.no_grad():
+                    ret = self.model_runner.model.compile_forward_draft(
+                        self.forward_batch[bs].input_ids,
+                        self.forward_batch[bs].positions,
+                        self.forward_batch[bs],
+                    )
+                self.forward_batch[bs].out_cache_loc = output_cache_loc_backup
+                self.forward_batch[bs].spec_info.hidden_states = hidden_states_backup
+                return ret
+
+            torch.npu.synchronize()
+            self.model_runner.tp_group.barrier()
+            run_once()
+
+    def can_run(self, forward_batch: ForwardBatch):
+        if not self.enable_torch_compile:
+            return super().can_run(forward_batch)
+
+        return (
+            not forward_batch.is_extend_in_batch
+        )
+
+    def forward(self, input_ids, position, forward_batch):
+        out = self.eagle_worker.draft_model_runner.model.forward(input_ids, position, forward_batch)
+        return out
+
+    def draft_forward(self, forward_batch):
+        # Parse args
+        spec_info = self.forward_batch[self.bs].spec_info
+        assert isinstance(spec_info, EagleDraftInput)
+        topk_p, topk_index, hidden_states = (
+            spec_info.topk_p,
+            spec_info.topk_index,
+            spec_info.hidden_states,
+        )
+        if self.eagle_worker.hot_token_id is not None:
+            topk_index = self.eagle_worker.hot_token_id[topk_index]
+
+        out_cache_loc = forward_batch.out_cache_loc.reshape(
+            self.raw_bs, self.topk, self.speculative_num_steps
+        )
+        out_cache_loc = out_cache_loc.permute((2, 0, 1)).reshape(
+            self.speculative_num_steps, -1
+        )
+
+        # Return values
+        score_list: List[torch.Tensor] = []
+        token_list: List[torch.Tensor] = []
+        parents_list: List[torch.Tensor] = []
+
+        # Forward multiple steps
+        scores = None
+        for i in range(self.speculative_num_steps):
+            input_ids, hidden_states, scores, tree_info = select_top_k_tokens(
+                i, topk_p, topk_index, hidden_states, scores, self.topk
+            )
+            score_list.append(tree_info[0])
+            token_list.append(tree_info[1])
+            parents_list.append(tree_info[2])
+
+            # We don't need to run the last forward. we get 1 token from draft prefill and (#spec steps - 1) tokens here
+            if i == self.speculative_num_steps - 1:
+                break
+
+            # Set inputs
+            self.forward_batch[self.bs].input_ids[:self.raw_num_token].copy_(input_ids[:self.raw_num_token])
+            # This is a temporary fix for the case that the user is using standalone
+            # speculative decoding and the draft model architecture is gpt-oss. gpt-oss
+            # rope kernel needs cache_loc to be contiguous.
+            if (
+                self.eagle_worker.server_args.speculative_algorithm == "STANDALONE"
+                and self.eagle_worker.model_config.hf_config.architectures[0] == "GptOssForCausalLM"
+            ):
+                out_cache_loc = out_cache_loc.contiguous()
+            self.forward_batch[self.bs].out_cache_loc[: self.raw_num_token].copy_(
+                out_cache_loc[i]
+            )
+            self.forward_batch[self.bs].positions.add_(1)
+            self.forward_batch[self.bs].attn_backend = self.model_runner.draft_attn_backend.attn_backends[i]
+            self.forward_batch[self.bs].spec_info.hidden_states[:self.raw_num_token].copy_(hidden_states[:self.raw_num_token])
+
+            # Run forward
+            with torch.no_grad():
+                logits_output, inference_time = self.model_runner.model.time_decorator_forward_draft(
+                    self.forward_batch[self.bs].input_ids,
+                    self.forward_batch[self.bs].positions,
+                    self.forward_batch[self.bs],
+                )
+                logging.info(f"For forward_mode: {get_execute_stage(forward_batch)},\
+                                draft inference time cost {(inference_time)*1000:.2f} ms")
+
+            if self.eagle_worker.server_args.enable_nan_detection:
+                detect_nan(logits_output)
+            probs = torch.softmax(logits_output.next_token_logits, dim=-1)
+            topk_p, topk_index = fast_topk(probs, self.topk, dim=-1)
+            if self.eagle_worker.hot_token_id is not None:
+                topk_index = self.eagle_worker.hot_token_id[topk_index]
+            hidden_states = logits_output.hidden_states
+
+        parent_list, top_scores_index, draft_tokens = organize_draft_results(
+            score_list, token_list, parents_list, self.speculative_num_draft_tokens
+        )
+
+        return parent_list, top_scores_index, draft_tokens
+
+    def replay_prepare(self, forward_batch: ForwardBatch):
+        if not self.enable_torch_compile:
+            return super().replay(forward_batch)
+
+        # pad, similar with front part in replay of parent class
+        raw_bs = forward_batch.batch_size
+        raw_num_token = raw_bs * self.num_tokens_per_bs
+
+        bs = self.compile_bs[0]
+        if bs != raw_bs:
+            self.forward_batch[bs].seq_lens.fill_(self.seq_len_fill_value)
+            self.forward_batch[bs].out_cache_loc.zero_()
+            self.forward_batch[bs].positions.zero_()
+
+        # Common inputs
+        self.forward_batch[bs].req_pool_indices[:raw_bs].copy_(forward_batch.req_pool_indices)
+        self.forward_batch[bs].seq_lens[:raw_bs].copy_(forward_batch.seq_lens)
+        self.forward_batch[bs].positions[:raw_num_token].copy_(forward_batch.positions)
+        self.forward_batch[bs].spec_info.topk_p[:raw_bs].copy_(forward_batch.spec_info.topk_p)
+        self.forward_batch[bs].spec_info.topk_index[:raw_bs].copy_(forward_batch.spec_info.topk_index)
+        self.forward_batch[bs].spec_info.hidden_states[:raw_bs].copy_(forward_batch.spec_info.hidden_states)
+
+        # TODO(ch-wan): support num_token_non_padded
+        if self.require_gathered_buffer:
+            self.forward_batch[bs].global_num_tokens_gpu.fill_(bs * self.num_tokens_per_bs)
+            self.forward_batch[bs].global_num_tokens_for_logprob_gpu.fill_(bs * self.num_tokens_per_bs)
+
+
+        if forward_batch.seq_lens_cpu is not None:
+            if bs != raw_bs:
+                self.forward_batch[bs].seq_lens_cpu.fill_(self.seq_len_fill_value)
+            self.forward_batch[bs].seq_lens_cpu[:raw_bs].copy_(forward_batch.seq_lens_cpu)
+
+        self.model_runner.draft_attn_backend.init_forward_metadata(self.forward_batch[bs], can_run_graph=True)
+        set_dp_buffer_len(self.forward_batch[bs].global_dp_buffer_len, bs * self.num_tokens_per_bs, dp_max_padding=True)
+        self.raw_bs = raw_bs
+        self.bs = bs
+        self.raw_num_token = raw_num_token
+
+    def replay(self, forward_batch):
+        self.replay_prepare(forward_batch)
+        out = self.draft_forward(forward_batch)
+        if self.bs != self.raw_bs:
+            out = self._postprocess_output_to_raw_bs(out, self.raw_bs)
+            forward_batch.batch_size = self.raw_bs
+            forward_batch.positions = self.forward_batch[self.bs].positions[:self.raw_num_token]
+            forward_batch.seq_lens = self.forward_batch[self.bs].seq_lens[:self.raw_bs]
+            forward_batch.req_pool_indices = self.forward_batch[self.bs].req_pool_indices[:self.raw_bs]
+            if forward_batch.seq_lens_cpu is not None:
+                forward_batch.seq_lens_cpu = self.forward_batch[self.bs].seq_lens_cpu[:self.raw_bs]
+
+        return out
+
+
