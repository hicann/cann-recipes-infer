@@ -151,6 +151,7 @@ class Qwen3MoeForCausalLMNextN(Qwen3MoeForCausalLM):
         self.moe_tp_size = get_moe_tensor_parallel_world_size()
         self.attn_tp_size = get_attention_tp_size()
         self.attn_dp_size = get_attention_dp_size()
+        self.load_lm_head_from_target = True
 
         # TODO mtp cache, sglang\python\sglang\srt\configs\model_config.py, which make
         # self.hf_config.num_hidden_layers = self.hf_config.num_nextn_predict_layers, check to delete the follow line
@@ -159,11 +160,11 @@ class Qwen3MoeForCausalLMNextN(Qwen3MoeForCausalLM):
         self.model = Qwen3MoeModelNextN(
             config, quant_config, prefix=add_prefix("model", prefix)
         )
-        self.lm_head = ParallelLMHead(
+        self.shared_head = ParallelLMHead(
             config.vocab_size,
             config.hidden_size,
             quant_config=quant_config,
-            prefix=add_prefix("lm_head", prefix),   # shared lm_head
+            prefix=add_prefix("shared_head", prefix),   # shared lm_head
             use_attn_tp_group=get_global_server_args().enable_dp_lm_head,
         )
         self.logits_processor = LogitsProcessor(config)
@@ -177,7 +178,7 @@ class Qwen3MoeForCausalLMNextN(Qwen3MoeForCausalLM):
     ) -> torch.Tensor:
         hidden_states = self.model(input_ids, positions, forward_batch)
         return self.logits_processor(
-            input_ids, hidden_states, self.lm_head, forward_batch
+            input_ids, hidden_states, self.shared_head, forward_batch
         )
 
     def extend(
diff --git a/python/sglang/srt/speculative/eagle_worker.py b/python/sglang/srt/speculative/eagle_worker.py
