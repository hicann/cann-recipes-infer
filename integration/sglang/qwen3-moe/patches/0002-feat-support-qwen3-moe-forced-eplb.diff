 from sglang.srt.eplb.expert_distribution import get_global_expert_distribution_recorder
 from sglang.srt.eplb.expert_location import ModelConfigForExpertLocation
 from sglang.srt.eplb.expert_location_dispatch import ExpertLocationDispatchInfo
-from sglang.srt.layers.dp_attention import get_attention_tp_rank, get_attention_tp_size
+from sglang.srt.layers.dp_attention import get_attention_tp_rank, get_attention_tp_size, get_attention_dp_size
 from sglang.srt.layers.layernorm import RMSNorm
 from sglang.srt.layers.linear import (
     QKVParallelLinear,
@@ -195,11 +195,11 @@ class Qwen3MoeSparseMoeBlockNPU(nn.Module):
                 "comm_quant_mode": 0
             }
 
-    def forward(self, hidden_states, forward_batch, cur_topk_list=None):
+    def forward(self, hidden_states, forward_batch):
         if hidden_states.shape[0] > 0:
             topk_idx, topk_weight, _, row_idx = self.gate(hidden_states)
-            if self.perfect_eplb:
-                topk_idx = cur_topk_list
+            if forward_batch.perfect_eplb and forward_batch.cur_topk_list is not None:
+                topk_idx = forward_batch.cur_topk_list
             topk_idx = topk_idx.to(torch.int32)
             if self.moe_tp_size > 1:
                 # MoE TP scene
@@ -1144,6 +1144,10 @@ class Qwen3MoeForCausalLM(nn.Module):
         )
         self.logits_processor = LogitsProcessor(config)
         self.capture_aux_hidden_states = False
+        self.moe_ep_size = get_moe_expert_parallel_world_size()
+        self.moe_tp_size = get_moe_tensor_parallel_world_size()
+        self.attn_tp_size = get_attention_tp_size()
+        self.attn_dp_size = get_attention_dp_size()
 
     def get_input_embeddings(self) -> nn.Embedding:
         return self.model.embed_tokens
@@ -1418,4 +1422,29 @@ class Qwen3MoeForCausalLM(nn.Module):
         )
 
 
+    def gen_cur_topk_idx(
+        self,
+        seq_len
+    ):
+        global_rank = dist.get_rank()
+        if self.moe_tp_size > 1:
+            expanded_tokens = self.config.num_experts_per_tok * seq_len
+            cur_topk_list_decode = []
+            for offset in range(self.moe_ep_size):
+                expert_start = offset * self.experts_per_rank
+                expert_end = expert_start + expanded_tokens
+                cur_topk_list_decode = cur_topk_list_decode + [i for i in range(expert_start, expert_end)]
+            cur_topk_list = torch.Tensor(cur_topk_list_decode).int().view(seq_len, -1).npu()
+        else:
+            expanded_tokens = self.config.num_experts_per_tok * seq_len * self.attn_dp_size // self.moe_ep_size
+            step_gap = self.config.num_experts // self.moe_ep_size if expanded_tokens < self.config.num_experts \
+                    else 1
+            cur_topk_list_decode = [
+                ((i + global_rank // step_gap * step_gap) * step_gap +
+                global_rank % step_gap) % self.config.num_experts for i in range(expanded_tokens)
+            ]
+            cur_topk_list = torch.Tensor(cur_topk_list_decode).int().view(seq_len * self.attn_dp_size // self.moe_ep_size, -1).npu()
+        return cur_topk_list
+
+
 EntryClass = Qwen3MoeForCausalLM
