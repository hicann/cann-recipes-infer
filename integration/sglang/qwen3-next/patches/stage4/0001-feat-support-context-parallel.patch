diff --git a/python/sglang/srt/layers/zigzag_cp_utils.py b/python/sglang/srt/layers/zigzag_cp_utils.py
new file mode 100644
index 000000000..9f17db999
--- /dev/null
+++ b/python/sglang/srt/layers/zigzag_cp_utils.py
@@ -0,0 +1,452 @@
+from collections import deque
+from dataclasses import dataclass
+from itertools import accumulate
+from typing import List, Tuple, Union
+
+import torch
+import torch.nn.functional as F
+import torch.distributed as dist
+
+from sglang.srt.distributed import (
+    context_model_parallel_all_gather,
+    get_tensor_model_parallel_rank,
+    get_tensor_model_parallel_world_size,
+    get_tp_group,
+)
+
+
+@dataclass
+class ZigzagContextParallelMetadata:
+    split_list: List[int] = None
+    max_rank_len: List[int] = None
+    zigzag_index: List[int] = None
+    global_zigzag_block_order: List[int] = None
+    per_rank_actual_token: List[int] = None
+    reverse_split_len: List[int] = None
+    cp_reverse_index: List[int] = None
+    kv_len_prev: int = -1
+    kv_len_next: int = -1
+    actual_seq_q_prev: int = -1
+    actual_seq_q_next: int = -1
+    total_seq_lens: torch.Tensor = None
+
+def linear_to_zigzag_all_to_all(local_tokens, forward_batch) -> torch.Tensor:
+    rank = get_tensor_model_parallel_rank()
+    world_size = get_tensor_model_parallel_world_size()
+    chunk_size = local_tokens.size(0)
+    group = get_tp_group().device_group
+
+    zigzag_order = forward_batch.zigzag_cp_metadata.global_zigzag_block_order
+
+    target_rank = zigzag_order.index(rank)
+
+    source_rank = zigzag_order[rank]
+
+    input_split_sizes = [0] * world_size
+    input_split_sizes[target_rank] = chunk_size
+
+    output_split_sizes = [0] * world_size
+    output_split_sizes[source_rank] = chunk_size
+
+    output_tokens = torch.empty_like(local_tokens)
+    dist.all_to_all_single(
+        output_tokens,
+        local_tokens,
+        output_split_sizes=output_split_sizes,
+        input_split_sizes=input_split_sizes,
+        group=group
+    )
+    return output_tokens
+
+
+def zigzag_to_linear_all_to_all(local_tokens, forward_batch) -> torch.Tensor:
+    rank = get_tensor_model_parallel_rank()
+    world_size = get_tensor_model_parallel_world_size()
+    chunk_size = local_tokens.size(0)
+    group = get_tp_group().device_group
+
+    zigzag_order = forward_batch.zigzag_cp_metadata.global_zigzag_block_order
+
+    target_rank = zigzag_order[rank]
+
+    source_rank = zigzag_order.index(rank)
+
+    input_split_sizes = [0] * world_size
+    input_split_sizes[target_rank] = chunk_size
+
+    output_split_sizes = [0] * world_size
+    output_split_sizes[source_rank] = chunk_size
+
+    output_tokens = torch.empty_like(local_tokens)
+    dist.all_to_all_single(
+        output_tokens,
+        local_tokens,
+        output_split_sizes=output_split_sizes,
+        input_split_sizes=input_split_sizes,
+        group=group
+    )
+    return output_tokens
+
+def cp_all_gather_reorganized_into_tensor(
+    input_: torch.Tensor, total_len, cp_size, forward_batch
+):
+    """
+    Allgather communication for context_parallel(kv_cache, index_k, hidden_states).
+    This implementation mainly consists of three parts:
+    Step 1, padding the input shape to unify the shape for allgather communication (the shape must be the same).
+    Step 2, allgather communication(async).
+    Step 3, removing the padding and reassembling the data according to the actual tokens.
+    """
+    max_len = (total_len + cp_size - 1) // cp_size
+    pad_size = max_len - input_.shape[0]
+    if pad_size > 0:
+        pad_config = [0] * (2 * (input_.dim() - 1)) + [0, pad_size]
+        input_ = F.pad(input_, tuple(pad_config), mode="constant", value=0)
+
+    input_tensor_all = context_model_parallel_all_gather(
+        input_.contiguous(), dim=0
+    )
+
+    outputs_list_max = list(
+        torch.split(input_tensor_all, forward_batch.zigzag_cp_metadata.max_rank_len, dim=0)
+    )
+    outputs = torch.cat(
+        [
+            outputs_list_max[index][:per_rank_len]
+            for index, per_rank_len in enumerate(
+                forward_batch.zigzag_cp_metadata.per_rank_actual_token
+            )
+        ],
+        dim=0,
+    )
+    return outputs
+
+
+def cp_all_gather_rearrange_output(input_tensor, cp_size, forward_batch):
+    """
+    |   +-----------before allgather------------+|
+    |   | cp0: block0, block7 |
+    |   | cp1: block1, block6 |
+    |   | cp2: block2, block5 |
+    |   | cp3: block3, block4 |
+    |
+    |   +----------before rerange---------------+|
+    | block0 | block7 | block1 | block6 | block2 | block5 | block3 | block4 |
+    |
+    |   +--------------result-------------------+
+    | block0 | block1 | block2 | block3 | block4 | block5 | block6 | block7 |
+    |   +-------------------------+
+    """
+    output_tensor = cp_all_gather_reorganized_into_tensor(
+        input_tensor,
+        forward_batch.zigzag_cp_metadata.total_seq_lens,
+        cp_size,
+        forward_batch,
+    )
+    outputs_list = list(
+        torch.split(
+            output_tensor, forward_batch.zigzag_cp_metadata.reverse_split_len, dim=0
+        )
+    )
+    output_tensor = torch.cat(
+        [outputs_list[i] for i in forward_batch.zigzag_cp_metadata.cp_reverse_index], dim=0
+    )
+    return output_tensor
+
+
+def get_prev_block_slices(forward_batch) -> List[Tuple[slice, slice]]:
+    """
+        Computes Q and KV slices for the Previous block in Zigzag CP.
+
+        This function accesses the Zigzag metadata to determine the exact range
+        of the first block assigned to the current rank.
+
+        Args:
+            forward_batch: The forward batch object containing `zigzag_cp_metadata`.
+
+        Returns:
+            List[Tuple[slice, slice]]: Slicing indices for the head block.
+        """
+    metadata = forward_batch.zigzag_cp_metadata
+    if metadata is None:
+        return []
+    block_len = metadata.actual_seq_q_prev
+    block_end_idx = metadata.kv_len_prev
+    block_start_idx = block_end_idx - block_len
+    return get_block_qkv_slices(
+        seq_lens=forward_batch.extend_seq_lens_cpu,
+        block_start_idx=block_start_idx,
+        block_len=block_len
+    )
+
+
+def get_next_block_slices(forward_batch) -> List[Tuple[slice, slice]]:
+    """
+    Computes Q and KV slices for the Next block in Zigzag CP.
+
+    This function accesses the Zigzag metadata to determine the exact range
+    of the second block assigned to the current rank.
+
+    Args:
+        forward_batch: The forward batch object containing `zigzag_cp_metadata`.
+
+    Returns:
+        List[Tuple[slice, slice]]: Slicing indices for the tail block.
+    """
+    metadata = forward_batch.zigzag_cp_metadata
+    if metadata is None:
+        return []
+    block_len = metadata.actual_seq_q_next
+    block_end_idx = metadata.kv_len_next
+    block_start_idx = block_end_idx - block_len
+    return get_block_qkv_slices(
+        seq_lens=forward_batch.extend_seq_lens_cpu,
+        block_start_idx=block_start_idx,
+        block_len=block_len,
+        query_offset=metadata.actual_seq_q_prev
+    )
+
+
+def get_block_qkv_slices(
+    seq_lens: Union[List[int], torch.Tensor],
+    block_start_idx: int,
+    block_len: int,
+    query_offset: int = 0,
+) -> List[Tuple[slice, slice]]:
+    """
+    Computes slicing indices for a specific data block across a batch of sequences.
+
+    This utility maps a contiguous physical block of tokens (defined by a global
+    start offset and length) to the corresponding logical sequences within a batch.
+    It calculates the intersection between the target block's range and each
+    sequence's range in the global token stream.
+
+    Visual Explanation:
+    -------------------
+    Imagine a batch of 2 sequences: Seq A (len 4) and Seq B (len 4).
+    The global stream is: [A0, A1, A2, A3, B0, B1, B2, B3]
+
+    Suppose we are processing a Block defined as: start=2, len=4.
+    Target Block covers global indices [2, 6): [A2, A3, B0, B1]
+
+    Global View:
+    Indices:       0   1   2   3   4   5   6   7
+    Stream:      [ A0  A1  A2  A3  B0  B1  B2  B3 ]
+    Sequence A:  |=======|-------|                  (Range: 0-4)
+    Sequence B:                  |-------|=======|  (Range: 4-8)
+    Target Block:        |===================|      (Range: 2-6)
+                         ^                   ^
+                     block_start         block_end
+
+    Intersections:
+    1. Seq A Intersection: [2, 4) -> [A2, A3]
+       - q_slice (relative to block start 2):  slice(0, 2)  -> indices 0, 1 in Block
+       - kv_slice (relative to global stream): slice(0, 4)  *See Note below
+         (Usually kv_slice maps to the sequence's local context or global cache)
+
+    2. Seq B Intersection: [4, 6) -> [B0, B1]
+       - q_slice (relative to block start 2):  slice(2, 4)  -> indices 2, 3 in Block
+       - kv_slice (relative to global stream): slice(4, 6)
+
+    Args:
+        seq_lens: A list or tensor containing the lengths of each sequence in the batch.
+        block_start_idx: The global starting index of the block in the flattened
+            token stream.
+        block_len: The length of the block.
+        query_offset: The starting index of this block within the actual
+            concatenated Query tensor. Defaults to 0.
+
+    Returns:
+        A list of tuples, where each tuple contains:
+        - q_slice (slice): Indices relative to the *local block buffer* (0 to block_len).
+          Used to extract the relevant query tokens for this sequence from the block.
+        - kv_slice (slice): Indices relative to the *global context*.
+          Used to index into the global KV cache or attention mask for this sequence.
+    """
+    block_start = block_start_idx
+    block_end = block_start + block_len
+
+    slices = []
+    global_cursor = 0
+
+    for seq_len in seq_lens:
+        seq_global_start = global_cursor
+        seq_global_end = global_cursor + seq_len
+
+
+        inter_start = max(seq_global_start, block_start)
+        inter_end = min(seq_global_end, block_end)
+
+        if inter_start < inter_end:
+
+            local_start = inter_start - block_start + query_offset
+            local_end = inter_end - block_start + query_offset
+
+            q_slice = slice(local_start, local_end)
+
+            kv_slice = slice(seq_global_start, inter_end)
+
+            slices.append((q_slice, kv_slice))
+
+        global_cursor += seq_len
+
+        if global_cursor >= block_end:
+            break
+
+    return slices
+
+def cp_split_and_rebuild_data(forward_batch, input_: torch.Tensor):
+    input_list = list(
+        torch.split(input_, forward_batch.zigzag_cp_metadata.split_list, dim=0)
+    )
+    result = torch.cat(
+        [input_list[i] for i in forward_batch.zigzag_cp_metadata.zigzag_index], dim=0
+    ).view(-1, input_.shape[-1])
+    return result
+
+
+def cp_split_and_rebuild_position(forward_batch, positions: torch.Tensor):
+    position_id_list = list(
+        torch.split(positions, forward_batch.zigzag_cp_metadata.split_list, dim=-1)
+    )
+    positions = torch.cat(
+        [position_id_list[i] for i in forward_batch.zigzag_cp_metadata.zigzag_index],
+        dim=-1,
+    )
+    return positions
+
+def get_block_zigzag_order(n, block_size):
+    """
+    Generate Block Zigzag Index
+    Args:
+        n: world_size (e.g., 8)
+        block_size: (e.g., 2)
+    Returns:
+        permuted_ranks: [0, 1, 6, 7, 2, 3, 4, 5]
+    """
+    if n % block_size != 0:
+        raise ValueError(f"World size {n} must be divisible by block_size {block_size}")
+
+    blocks = []
+    for i in range(0, n, block_size):
+        blocks.append(list(range(i, i + block_size)))
+
+    dq = deque(blocks)
+    ordered_blocks = []
+    while dq:
+        ordered_blocks.append(dq.popleft())
+        if dq:
+            ordered_blocks.append(dq.pop())
+
+    flat_order = []
+    for b in ordered_blocks:
+        flat_order.extend(b)
+
+    return flat_order
+
+def prepare_zigzag_context_parallel_metadata(
+    kv_len,
+    cp_rank,
+    cp_size,
+    seqs_len,
+) -> ZigzagContextParallelMetadata:
+    """prepare_zigzag_context_parallel_metadata - Zigzag Load Balancing
+
+    Example (CP_SIZE == 4):
+    Description:
+    1. Start with a full-length sequence (kv_len).
+    2. Split the sequence into 2 * CP_SIZE blocks (block0 to block7).
+    3. Assign blocks to different CP ranks using a zigzag strategy to
+       balance the causal attention computation load.
+
+    +---------------------------------+
+    |        cp_split_tokens          |
+    +---------------------------------+
+    |                                 |
+    |    sequence_with_full_length    |
+    |             | split (cp_size * 2) |
+    |   +-------------------------+   |
+    |   | block0 | block1 | block2 | block3 | block4 | block5 | block6 | block7 |
+    |   +-------------------------+   |
+    |             | zigzag assign     |
+    |   +---------------------------------------+
+    |   | cp_rank0 (rank_prev/next): block0, block7 | (Lightest + Heaviest)
+    |   | cp_rank1 (rank_prev/next): block1, block6 |
+    |   | cp_rank2 (rank_prev/next): block2, block5 |
+    |   | cp_rank3 (rank_prev/next): block3, block4 | (Medium + Medium)
+    |   +---------------------------------------+
+
+    Why zigzag assign?
+    - Causal Attention Load Imbalance:
+        In standard chunking, attention calculation load increases quadratically
+        or linearly with position index (depending on implementation):
+        * The first rank handles early tokens (short history -> low compute).
+        * The last rank handles late tokens (long history -> high compute).
+    - Zigzag Solution:
+        * By assigning one "head" block (early position, low load) and one
+          "tail" block (late position, high load) to each CP rank, the total
+          computational load is roughly balanced across all devices.
+
+    Args:
+        kv_len: Total sequence length.
+        cp_rank: Current rank ID in the Context Parallel group.
+        cp_size: Size of the Context Parallel group.
+        seqs_len: Reserved for batch processing (currently supports bs=1).
+    """
+    cp_segment_num = cp_size * 2
+    base_block_len = kv_len // cp_segment_num
+    remainder = kv_len % cp_segment_num
+    world_size = get_tensor_model_parallel_world_size()
+
+    split_list = [base_block_len] * cp_segment_num
+
+    for i in range(remainder):
+        split_list[i] += 1
+
+    idx_prev = cp_rank
+    idx_next = cp_segment_num - cp_rank - 1
+    zigzag_index = [idx_prev, idx_next]
+
+    global_zigzag_block_order = get_block_zigzag_order(world_size, world_size // cp_segment_num)
+
+    seq_max_rank_len = (kv_len + cp_size - 1) // cp_size
+    max_rank_len = [seq_max_rank_len] * cp_size
+
+    per_rank_actual_token = []
+    for r in range(cp_size):
+        r_prev = r
+        r_next = cp_segment_num - r - 1
+        per_rank_actual_token.append(split_list[r_prev] + split_list[r_next])
+
+    reverse_split_len = [
+        length
+        for i in range(cp_size)
+        for length in (split_list[i], split_list[cp_segment_num - i - 1])
+    ]
+
+    evens = list(range(0, cp_segment_num, 2))
+    odds_reversed = list(range(cp_segment_num - 1, 0, -2))
+    cp_reverse_index = evens + odds_reversed
+
+    prefix_sum_list = list(accumulate(split_list))
+
+    kv_len_prev = prefix_sum_list[idx_prev]
+    kv_len_next = prefix_sum_list[idx_next]
+
+    actual_seq_q_prev = split_list[idx_prev]
+    actual_seq_q_next = split_list[idx_next]
+
+    return ZigzagContextParallelMetadata(
+        split_list=split_list,
+        max_rank_len=max_rank_len,
+        zigzag_index=zigzag_index,
+        global_zigzag_block_order=global_zigzag_block_order,
+        per_rank_actual_token=per_rank_actual_token,
+        reverse_split_len=reverse_split_len,
+        cp_reverse_index=cp_reverse_index,
+        kv_len_prev=kv_len_prev,
+        kv_len_next=kv_len_next,
+        actual_seq_q_prev=actual_seq_q_prev,
+        actual_seq_q_next=actual_seq_q_next,
+        total_seq_lens=torch.tensor(kv_len, dtype=torch.int32),
+    )
