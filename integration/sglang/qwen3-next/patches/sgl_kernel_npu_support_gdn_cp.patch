         return g, o, A, final_state, w, h, v_new
 
 
+def chunk_gated_delta_rule_zeco_fwd(
+    q: torch.Tensor,
+    k: torch.Tensor,
+    v: torch.Tensor,
+    g: torch.Tensor,
+    beta: torch.Tensor,
+    scale: float,
+    initial_state: torch.Tensor,
+    output_final_state: bool,
+    comm_stream: torch.npu.Stream,
+    group,
+    cu_seqlens: Optional[torch.LongTensor] = None,
+):
+    g = chunk_local_cumsum(g, chunk_size=64, cu_seqlens=cu_seqlens)
+    # obtain WY representation. u is actually the new v.
+    A = chunk_scaled_dot_kkt_fwd(
+        k=k, beta=beta, g_cumsum=g, cu_seqlens=cu_seqlens, output_dtype=torch.float32
+    )
+    A = solve_tril(A=A, cu_seqlens=cu_seqlens, output_dtype=k.dtype)
+    w, u = recompute_w_u_fwd(
+        k=k,
+        v=v,
+        beta=beta,
+        A=A,
+        g_cumsum=g,
+        cu_seqlens=cu_seqlens,
+    )
+    if group.is_first_rank:
+        h, v_new, final_state = chunk_gated_delta_rule_fwd_h(
+            k=k,
+            w=w,
+            u=u,
+            g=g,
+            initial_state=initial_state,
+            output_final_state=output_final_state,
+            cu_seqlens=cu_seqlens,
+        )
+        final_state = final_state.to(v.dtype).contiguous()
+        comm_stream.wait_stream(torch.npu.default_stream())
+        with torch.npu.stream(comm_stream):
+            send_handle = dist.isend(final_state, dst=group.next_rank)
+            global_final_state = torch.empty_like(final_state)
+            broadcast_handle = torch.distributed.broadcast(global_final_state,
+                                                           src=group.last_rank,
+                                                           group=group.device_group,
+                                                           async_op=True)
+        o = chunk_fwd_o(
+            q=q,
+            k=k,
+            v=v_new,
+            h=h,
+            g=g,
+            scale=scale,
+            cu_seqlens=cu_seqlens,
+        )
+    else:
+        B, S, H, V, K = *v.shape, k.shape[-1]
+        N = B if cu_seqlens is None else len(cu_seqlens) - 1
+        initial_state = torch.empty((N, H, K, V), dtype=torch.bfloat16, device=v.device)
+        with torch.npu.stream(comm_stream):
+            recv_handle = dist.irecv(initial_state, src=group.prev_rank)
+        a, b = chunk_gated_delta_rule_fwd_ab(
+            k=k,
+            w=w,
+            u=u,
+            g=g,
+            cu_seqlens=cu_seqlens,
+        )
+        recv_handle.wait()
+        torch.npu.default_stream().wait_stream(comm_stream)
+        final_state = chunk_final_state_zeco(a, b, initial_state, cu_seqlens=cu_seqlens)
+        comm_stream.wait_stream(torch.npu.default_stream())
+        with torch.npu.stream(comm_stream):
+            if not group.is_last_rank:
+                send_handle = dist.isend(final_state, dst=group.next_rank)
+                global_final_state = torch.empty_like(final_state)
+            else:
+                global_final_state = final_state
+            broadcast_handle = torch.distributed.broadcast(global_final_state,
+                                                           src=group.last_rank,
+                                                           group=group.device_group,
+                                                           async_op=True)
+        o, h = chunk_fwd_o_zeco(
+            q=q,
+            k=k,
+            v=u,
+            w=w,
+            a=a,
+            b=b,
+            g=g,
+            scale=scale,
+            initial_state=initial_state,
+            cu_seqlens=cu_seqlens,
+        )
+
+    if not group.is_last_rank:
+        send_handle.wait()
+    broadcast_handle.wait()
+    if SUPPRESS_LEVEL < 3:
+        return g, o, A, global_final_state, None, h, None
+    elif SUPPRESS_LEVEL >= 3:
+        return g, o, A, global_final_state, w, h, None
+
+
