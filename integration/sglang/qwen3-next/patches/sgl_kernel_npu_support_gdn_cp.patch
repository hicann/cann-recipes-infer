+# Adapted and Merge from
+#   https://github.com/sglang/python/sglang/srt/layers/attention/fla/chunk_o.py
+# -*- coding: utf-8 -*-
+# Copyright (c) 2023-2025, By Triton_Ascend & sglang_ascend
+
+from typing import Optional
+
+import torch
+import triton
+import triton.language as tl
+from sgl_kernel_npu.fla.utils import (
+    prepare_chunk_indices,
+    prepare_chunk_offsets,
+    safe_exp,
+)
+
+
+@triton.heuristics(
+    {
+        "USE_G": lambda args: args["g"] is not None,
+        "IS_VARLEN": lambda args: args["cu_seqlens"] is not None,
+        "USE_INITIAL_STATE": lambda args: args["h0"] is not None,
+    }
+)
+@triton.jit(do_not_specialize=["T"])
+def chunk_fwd_kernel_o_zeco_npu_kernel(
+    q,
+    k,
+    v,
+    w,
+    a,
+    b,
+    h0,
+    h,
+    g,
+    o,
+    cu_seqlens,
+    chunk_offsets,
+    scale,
+    T,
+    H: tl.constexpr,
+    Hg: tl.constexpr,
+    K: tl.constexpr,
+    V: tl.constexpr,
+    BT: tl.constexpr,
+    BK: tl.constexpr,
+    BV: tl.constexpr,
+    BKK: tl.constexpr,
+    USE_G: tl.constexpr,
+    IS_VARLEN: tl.constexpr,
+    USE_INITIAL_STATE: tl.constexpr
+):
+    i_v, i_nh = tl.program_id(0), tl.program_id(1)
+    i_n, i_h = i_nh // H, i_nh % H
+    T_max = T
+
+    if IS_VARLEN:
+        bos, eos = tl.load(cu_seqlens + i_n).to(tl.int32), tl.load(
+            cu_seqlens + i_n + 1
+        ).to(tl.int32)
+        T = eos - bos
+        NT = tl.cdiv(T, BT)
+        boh = tl.load(chunk_offsets + i_n).to(tl.int64)
+    else:
+        bos, eos = i_n * T, i_n * T + T
+        NT = tl.cdiv(T, BT)
+        boh = i_n * NT
+
+    # offset calculation
+    q += (bos * Hg + i_h // (H // Hg)) * K
+    k += (bos * Hg + i_h // (H // Hg)) * K
+    w += (bos * H + i_h) * K
+    v += (bos * H + i_h) * V
+    o += (bos * H + i_h) * V
+
+    # [K, BV]
+    b_h_curr = tl.zeros([K, BV], dtype=h.dtype.element_ty)
+    if USE_INITIAL_STATE:
+        h0 += i_nh * K * V
+        p_h0 = tl.make_block_ptr(
+            h0, (K, V), (V, 1), (0, i_v * BV), (K, BV), (1, 0)
+        )
+        b_h_curr = tl.load(p_h0, boundary_check=(0, 1), padding_option="zero")
+    h_base = h + (boh * H + i_h).to(tl.int64) * K * V
+    p_h_ = tl.make_block_ptr(
+            h_base, (K, V), (V, 1), (0, i_v * BV), (K, BV), (1, 0)
+        )
+    tl.store(p_h_, b_h_curr.to(p_h_.dtype.element_ty), boundary_check=(0, 1))
+
+    for i_t in range(NT):
+        i_tg = boh + i_t
+        h_base = h + (i_tg * H + i_h).to(tl.int64) * K * V
+        a_base = a + (i_tg * H + i_h).to(tl.int64) * K * K
+        b_base = b + (i_tg * H + i_h).to(tl.int64) * K * V
+        b_wh = tl.zeros([BT, BV], dtype=tl.float32)
+        b_o = tl.zeros([BT, BV], dtype=tl.float32)
+        b_A = tl.zeros([BT, BT], dtype=tl.float32)
+        for i_k in range(tl.cdiv(K, BK)):
+            p_q = tl.make_block_ptr(
+                q, (T, K), (Hg * K, 1), (i_t * BT, i_k * BK), (BT, BK), (1, 0)
+            )
+            # [BT, BK]
+            b_q = tl.load(p_q, boundary_check=(0, 1), padding_option="zero")
+
+            p_k = tl.make_block_ptr(
+                k, (K, T), (1, Hg * K), (i_k * BK, i_t * BT), (BK, BT), (0, 1)
+            )
+            # [BK, BT]
+            b_k = tl.load(p_k, boundary_check=(0, 1), padding_option="zero")
+
+            p_h = tl.make_block_ptr(
+                h_base, (K, V), (V, 1), (i_k * BK, i_v * BV), (BK, BV), (1, 0)
+            )
+            # [BK, BV]
+            b_h = tl.load(p_h, boundary_check=(0, 1), padding_option="zero")
+
+            p_w = tl.make_block_ptr(
+                w, (T, K), (H * K, 1), (i_t * BT, i_k * BK), (BT, BK), (1, 0))
+            # [BT, BK]
+            b_w = tl.load(p_w, boundary_check=(0, 1), padding_option="zero")
+
+            # [BT, BK] @ [BK, BV] -> [BT, BV]
+            b_wh = tl.dot(b_w, b_h, b_wh.to(tl.float32))
+            # [BT, BK] @ [BK, BV] -> [BT, BV]
+            b_o = tl.dot(b_q, b_h, b_o.to(tl.float32))
+            # [BT, BK] @ [BK, BT] -> [BT, BT]
+            b_A = tl.dot(b_q, b_k, b_A.to(tl.float32))
+
+            h_next_base = h + ((i_tg + 1) * H + i_h).to(tl.int64) * K * V
+            p_h_next = tl.make_block_ptr(
+                h_next_base, (K, V), (V, 1), (i_k * BK, i_v * BV), (BKK, BV), (1, 0)
+            )
+            p_a = tl.make_block_ptr(
+                a_base, (K, K), (K, 1), (i_k * BK, i_k * BK), (BKK, BK), (1, 0)
+            )
+            p_b = tl.make_block_ptr(
+                b_base, (K, V), (V, 1), (i_k * BK, i_v * BV), (BKK, BV), (1, 0)
+            )
+            for _ in range(tl.cdiv(BK, BKK)):
+                # [BKK, BK]
+                b_a = tl.load(p_a, boundary_check=(0, 1), padding_option="zero")
+                # [BKK, BV]
+                b_b = tl.load(p_b, boundary_check=(0, 1), padding_option="zero")
+                # [BKK, BK] @ [BK, BV] + [BKK, BV]
+                h_new = tl.dot(b_a, b_h.to(b_a.dtype), b_b.to(tl.float32))
+                tl.store(p_h_next, h_new.to(p_h_next.dtype.element_ty), boundary_check=(0, 1))
+
+                p_a = tl.advance(p_a, [BKK, 0])
+                p_b = tl.advance(p_b, [BKK, 0])
+                p_h_next = tl.advance(p_h_next, [BKK, 0])
+
+        if USE_G:
+            offs_t = i_t * BT + tl.arange(0, BT)
+            mask_t = offs_t < T
+            g_ptr = g + bos + i_h * T_max
+            b_g = tl.load(g_ptr + offs_t, mask=mask_t, other=0.0)
+
+            b_o = b_o * tl.exp(b_g)[:, None]
+            b_A = b_A * safe_exp(b_g[:, None] - b_g[None, :])
+
+        o_i = tl.arange(0, BT).to(tl.float32)
+        m_A = o_i[:, None] >= o_i[None, :]
+        b_A = tl.where(m_A, b_A, 0)
+
+        p_v = tl.make_block_ptr(
+            v, (T, V), (H * V, 1), (i_t * BT, i_v * BV), (BT, BV), (1, 0)
+        )
+        p_o = tl.make_block_ptr(
+            o, (T, V), (H * V, 1), (i_t * BT, i_v * BV), (BT, BV), (1, 0)
+        )
+        b_v = tl.load(p_v, boundary_check=(0, 1), padding_option="zero")
+        b_v -= b_wh.to(b_v.dtype)
+
+        # to fix mma -> mma layout conversion
+        # already solved by triton v3.2 or higher
+        b_o = b_o * scale + tl.dot(b_A.to(b_v.dtype), b_v) * scale
+
+        tl.store(p_o, b_o.to(p_o.dtype.element_ty), boundary_check=(0, 1))
+
+
+def chunk_fwd_o_zeco_npu(
+    q: torch.Tensor,
+    k: torch.Tensor,
+    v: torch.Tensor,
+    w: torch.Tensor,
+    a: torch.Tensor,
+    b: torch.Tensor,
+    initial_state: Optional[torch.Tensor] = None,
+    g: Optional[torch.Tensor] = None,  # cumsum of log decay
+    scale: Optional[float] = None,
+    cu_seqlens: Optional[torch.LongTensor] = None,
+    chunk_size: int = 64,
+) -> torch.Tensor:
+    B, T, Hg, K, V = *q.shape, v.shape[-1]
+    H = v.shape[-2]
+
+    BT = chunk_size
+    chunk_indices = (
+        prepare_chunk_indices(cu_seqlens, BT) if cu_seqlens is not None else None
+    )
+    NT = triton.cdiv(T, BT) if cu_seqlens is None else len(chunk_indices)
+    if scale is None:
+        scale = k.shape[-1] ** -0.5
+
+    h = k.new_empty(B, NT, H, K, V)
+    o = torch.empty_like(v)
+    if cu_seqlens is None:
+        N, chunk_offsets = B, None
+    else:
+        N, chunk_offsets = (
+            len(cu_seqlens) - 1,
+            prepare_chunk_offsets(cu_seqlens, BT),
+        )
+
+    def grid(meta):
+        return (triton.cdiv(V, meta["BV"]), N * H)
+
+    # Pre-transpose tensors outside the kernel to ensure contiguous memory access within the kernel
+    # avoiding scattered (non-contiguous) access that may lead to axis expansion
+    g = g.transpose(1, 2).contiguous()
+    chunk_fwd_kernel_o_zeco_npu_kernel[grid](
+        q,
+        k,
+        v,
+        w,
+        a,
+        b,
+        initial_state,
+        h,
+        g,
+        o,
+        cu_seqlens,
+        chunk_offsets,
+        scale,
+        T=T,
+        H=H,
+        Hg=Hg,
+        K=K,
+        V=V,
+        BT=BT,
+        BK=128,
+        BV=128,
+        BKK=64,
+        num_warps=4,
+        num_stages=2,
+    )
+    return o, h
