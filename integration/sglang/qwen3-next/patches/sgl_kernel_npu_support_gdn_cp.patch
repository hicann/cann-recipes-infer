+++ b/python/sgl_kernel_npu/sgl_kernel_npu/fla/chunk_delta_h_zeco.py
@@ -0,0 +1,308 @@
+# Adapted and Merge from
+#   https://github.com/sglang/python/sglang/srt/layers/attention/fla/chunk_delta_h.py
+# -*- coding: utf-8 -*-
+# Copyright (c) 2023-2025, By Triton_Ascend & sglang_ascend
+
+from typing import Optional, Tuple
+
+import torch
+import triton
+import triton.language as tl
+from sgl_kernel_npu.fla.utils import (
+    exp,
+    prepare_chunk_indices,
+    prepare_chunk_offsets,
+    safe_exp,
+)
+
+
+@triton.heuristics(
+    {
+        "USE_G": lambda args: args["g"] is not None,
+        "IS_VARLEN": lambda args: args["cu_seqlens"] is not None,
+    }
+)
+@triton.jit(do_not_specialize=["T"])
+def chunk_gated_delta_rule_fwd_kernel_h_blockdim64_zeco_npu_kernel(
+    k,
+    v,
+    w,
+    g,
+    a,
+    b,
+    a_curr,
+    b_curr,
+    cu_seqlens,
+    chunk_offsets,
+    T,
+    H: tl.constexpr,
+    Hg: tl.constexpr,
+    K: tl.constexpr,
+    V: tl.constexpr,
+    BT: tl.constexpr,
+    BK: tl.constexpr,
+    BV: tl.constexpr,
+    USE_G: tl.constexpr,
+    IS_VARLEN: tl.constexpr,
+):
+    i_nh = tl.program_id(1)
+    i_n, i_h = i_nh // H, i_nh % H
+    T_max = 1 * T
+    if IS_VARLEN:
+        bos, eos = tl.load(cu_seqlens + i_n).to(tl.int32), tl.load(
+            cu_seqlens + i_n + 1
+        ).to(tl.int32)
+        T = eos - bos
+        NT = tl.cdiv(T, BT)
+        boh = tl.load(chunk_offsets + i_n).to(tl.int32)
+    else:
+        bos, eos = i_n * T, i_n * T + T
+        NT = tl.cdiv(T, BT)
+        boh = i_n * NT
+
+    k += (bos * Hg + i_h // (H // Hg)) * K
+    w += (bos * H + i_h) * K
+    v += (bos * H + i_h) * V
+    a_curr += i_nh * K * K
+    b_curr += i_nh * K * V
+
+    for i_t in range(NT):
+        i_tg = boh + i_t
+        a_base = a + (i_tg * H + i_h).to(tl.int64) * K * K
+        b_base = b + (i_tg * H + i_h).to(tl.int64) * K * V
+
+        p_k = tl.make_block_ptr(
+            k, (K, T), (1, Hg * K), (0, i_t * BT), (K, BT), (0, 1)
+        )
+        # [K, BT]
+        b_k = tl.load(p_k, boundary_check=(0, 1), padding_option="zero")
+
+        if USE_G:
+            offs_t = i_t * BT + tl.arange(0, BT)
+            mask_t = offs_t < T
+            last_idx = min((i_t + 1) * BT, T) - 1
+            b_g_last = tl.load(g + bos + i_h * T_max + last_idx)
+
+            g_ptr = g + bos + i_h * T_max
+            b_g = tl.load(g_ptr + offs_t, mask=mask_t, other=0.0)
+            b_k = b_k * safe_exp(b_g_last - b_g)[None, :]
+            b_g_last = tl.exp(b_g_last)
+
+        p_w = tl.make_block_ptr(
+            w, (T, K), (H * K, 1), (i_t * BT, 0), (BT, K), (1, 0)
+        )
+        p_a = tl.make_block_ptr(
+            a_base, (K, K), (K, 1), (0, 0), (K, BK), (1, 0)
+        )
+        p_b = tl.make_block_ptr(
+            b_base, (K, V), (V, 1), (0, 0), (K, BV), (1, 0)
+        )
+        p_a_curr = tl.make_block_ptr(
+            a_curr, (K, K), (K, 1), (0, 0), (K, BK), (1, 0)
+        )
+        p_b_curr = tl.make_block_ptr(
+            b_curr, (K, V), (V, 1), (0, 0), (K, BV), (1, 0)
+        )
+        p_v = tl.make_block_ptr(
+            v, (T, V), (H * V, 1), (i_t * BT, 0), (BT, BV), (1, 0)
+        )
+
+        # [BT, K]
+        b_w = tl.load(p_w, boundary_check=(0, 1), padding_option="zero")
+        for _ in range(tl.cdiv(V, BV)):
+            # [BT, BV]
+            b_v = tl.load(p_v, boundary_check=(0, 1), padding_option="zero").to(tl.float32)
+            # [K, BV]
+            b_b_curr = tl.load(p_b_curr, boundary_check=(0, 1), padding_option="zero")
+            # [BT, K] @ [K, BV] - [BT, BV]
+            b_v = tl.dot(b_w, b_b_curr.to(b_w.dtype), -b_v)
+            # [K, BV] - [K, BT] @ [BT, BV]
+            b_b_curr = b_b_curr * b_g_last - tl.dot(b_k, b_v)
+            tl.store(p_b_curr, b_b_curr.to(p_b_curr.dtype.element_ty), boundary_check=(0, 1))
+            tl.store(p_b, b_b_curr.to(p_b.dtype.element_ty), boundary_check=(0, 1))
+            p_b = tl.advance(p_b, [0, BV])
+            p_b_curr = tl.advance(p_b_curr, [0, BV])
+
+        # [K, BT] @ [BT, K]
+        a_loc = tl.dot(b_k.to(b_w.dtype), b_w)
+        for _ in range(tl.cdiv(K, BK)):
+            # [K, BK]
+            b_a_curr = tl.load(p_a_curr, boundary_check=(0, 1), padding_option="zero")
+            # [K, BK] - [K, K] @ [K, BK]
+            b_a_curr = b_a_curr * b_g_last - tl.dot(a_loc.to(b_a_curr.dtype), b_a_curr)
+            tl.store(p_a_curr, b_a_curr.to(p_a_curr.dtype.element_ty), boundary_check=(0, 1))
+            tl.store(p_a, b_a_curr.to(p_a.dtype.element_ty), boundary_check=(0, 1))
+            p_a = tl.advance(p_a, [0, BK])
+            p_a_curr = tl.advance(p_a_curr, [0, BK])
+
+
+def chunk_gated_delta_rule_fwd_ab_npu(
+    k: torch.Tensor,
+    w: torch.Tensor,
+    u: torch.Tensor,
+    g: Optional[torch.Tensor] = None,
+    chunk_size: int = 64,
+    cu_seqlens: Optional[torch.LongTensor] = None,
+) -> Tuple[torch.Tensor, torch.Tensor]:
+    B, T, Hg, K, V = *k.shape, u.shape[-1]
+    H = u.shape[-2]
+    BT = chunk_size
+
+    chunk_indices = (
+        prepare_chunk_indices(cu_seqlens, chunk_size)
+        if cu_seqlens is not None
+        else None
+    )
+    # N: the actual number of sequences in the batch with either equal or variable lengths
+    if cu_seqlens is None:
+        N, NT, chunk_offsets = B, triton.cdiv(T, BT), None
+    else:
+        N, NT, chunk_offsets = (
+            len(cu_seqlens) - 1,
+            len(chunk_indices),
+            prepare_chunk_offsets(cu_seqlens, BT),
+        )
+    assert K == 128, "current kernel does not support head dimension other than 128."
+    a = k.new_empty(B, NT, H, K, K)
+    b = k.new_empty(B, NT, H, K, V)
+    a_curr = torch.eye(K, dtype=a.dtype, device=a.device).repeat(N, H, 1, 1)
+    b_curr = torch.zeros(N, H, K, V, dtype=b.dtype, device=b.device)
+
+    # Pre-transpose tensors outside the kernel to ensure contiguous memory access within the kernel
+    # avoiding scattered (non-contiguous) access that may lead to axis expansion
+    g = g.transpose(1, 2).contiguous()
+
+    def grid(meta):
+        return (1, N * H)
+
+    chunk_gated_delta_rule_fwd_kernel_h_blockdim64_zeco_npu_kernel[grid](
+        k=k,
+        v=u,
+        w=w,
+        a=a,
+        b=b,
+        a_curr=a_curr,
+        b_curr=b_curr,
+        g=g,
+        cu_seqlens=cu_seqlens,
+        chunk_offsets=chunk_offsets,
+        T=T,
+        H=H,
+        Hg=Hg,
+        K=K,
+        V=V,
+        BT=BT,
+        BK=128,
+        BV=128,
+    )
+    return a, b
+
+
+@triton.heuristics(
+    {
+        "IS_VARLEN": lambda args: args["cu_seqlens"] is not None,
+    }
+)
+@triton.jit(do_not_specialize=["NT"])
+def chunk_final_state_zeco_kernel(
+    a,
+    b,
+    initial_state,
+    final_state,
+    cu_seqlens,
+    chunk_offsets,
+    NT,
+    H: tl.constexpr,
+    K: tl.constexpr,
+    V: tl.constexpr,
+    BK: tl.constexpr,
+    BV: tl.constexpr,
+    BKK: tl.constexpr,
+    IS_VARLEN: tl.constexpr,
+):
+    i_nh = tl.program_id(1)
+    i_n, i_h = i_nh // H, i_nh % H
+
+    if IS_VARLEN:
+        last_chunk_idx = tl.load(chunk_offsets + i_n + 1).to(tl.int32) - 1
+    else:
+        last_chunk_idx = i_n * NT + NT - 1
+
+    a_base = a + (last_chunk_idx * H + i_h).to(tl.int64) * K * K
+    b_base = b + (last_chunk_idx * H + i_h).to(tl.int64) * K * V
+    h0_base = initial_state + i_nh * K * V
+    ht_base = final_state + i_nh * K * V
+
+    for iv in range(tl.cdiv(V, BV)):
+        v_start = iv * BV
+        for ik_out in range(tl.cdiv(K, BKK)):
+            k_out_start = ik_out * BKK
+            b_ht = tl.zeros([BKK, BV], dtype=tl.float32)
+
+            for ik_in in range(tl.cdiv(K, BK)):
+                k_in_start = ik_in * BK
+                p_a = tl.make_block_ptr(
+                    a_base, (K, K), (K, 1), (k_out_start, k_in_start), (BKK, BK), (1, 0)
+                )
+                b_a = tl.load(p_a, boundary_check=(0, 1), padding_option="zero")
+
+                p_h0 = tl.make_block_ptr(
+                    h0_base, (K, V), (V, 1), (k_in_start, v_start), (BK, BV), (1, 0)
+                )
+                b_h0 = tl.load(p_h0, boundary_check=(0, 1), padding_option="zero")
+
+                b_ht = tl.dot(b_a, b_h0, b_ht)
+
+            p_b = tl.make_block_ptr(
+                b_base, (K, V), (V, 1), (k_out_start, v_start), (BKK, BV), (1, 0)
+            )
+            b_b = tl.load(p_b, boundary_check=(0, 1), padding_option="zero")
+            b_ht += b_b.to(tl.float32)
+
+            p_ht = tl.make_block_ptr(
+                ht_base, (K, V), (V, 1), (k_out_start, v_start), (BKK, BV), (1, 0)
+            )
+            tl.store(p_ht, b_ht.to(p_ht.dtype.element_ty), boundary_check=(0, 1))
+
+
+def chunk_final_state_zeco_npu(
+    a: torch.Tensor,
+    b: torch.Tensor,
+    initial_state: torch.Tensor,
+    cu_seqlens: Optional[torch.LongTensor] = None,
+    chunk_size: int = 64,
+) -> torch.Tensor:
+    B, NT, H, K, _ = a.shape
+    V = b.shape[-1]
+
+    if cu_seqlens is None:
+        N = B
+        chunk_offsets = None
+    else:
+        N = len(cu_seqlens) - 1
+        chunk_offsets = prepare_chunk_offsets(cu_seqlens, chunk_size)
+
+    final_state = torch.empty_like(initial_state)
+
+    def grid(meta):
+        return (1, N * H)
+
+    chunk_final_state_zeco_kernel[grid](
+        a=a,
+        b=b,
+        initial_state=initial_state,
+        final_state=final_state,
+        cu_seqlens=cu_seqlens,
+        chunk_offsets=chunk_offsets,
+        NT=NT,
+        H=H,
+        K=K,
+        V=V,
+        BK=128,
+        BV=128,
+        BKK=64,
+        num_warps=4,
+        num_stages=2,
+    )
+
+    return final_state
diff --git a/python/sgl_kernel_npu/sgl_kernel_npu/fla/chunk_o_zeco.py b/python/sgl_kernel_npu/sgl_kernel_npu/fla/chunk_o_zeco.py
