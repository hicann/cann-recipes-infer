+    def single_batch_overlapped_causal_conv1d_update(
+        self,
+        mixed_qkv: torch.Tensor,
+        weight: torch.Tensor,
+        bias: torch.Tensor,
+        activation: torch.Tensor,
+        conv_states: torch.Tensor,
+        has_initial_state: torch.Tensor,
+        cache_indices: torch.Tensor,
+        query_start_loc: torch.Tensor,
+        cp_group,
+        seq_len,
+    ):
+        """Faster processing of a single batched input"""
+        overlap_size = weight.shape[1] - 1
+        overlap = mixed_qkv.new_zeros((overlap_size, mixed_qkv.shape[1]))
+        overlapped_query_start_loc = query_start_loc.clone()
+        if not cp_group.is_last_rank:
+            send_handle = dist.isend(mixed_qkv[query_start_loc[-1] - overlap_size:query_start_loc[-1]].contiguous(),
+                                     dst=cp_group.next_rank)
+        if not cp_group.is_first_rank:
+            dist.recv(overlap, src=cp_group.prev_rank)
+        mixed_qkv = torch.cat((overlap, mixed_qkv))
+        overlapped_query_start_loc[-1] += overlap_size
+        mixed_qkv = causal_conv1d_fn_npu(
+            mixed_qkv.transpose(0, 1),
+            weight,
+            bias,
+            activation=activation,
+            conv_states=conv_states,
+            has_initial_state=has_initial_state,
+            cache_indices=cache_indices,
+            query_start_loc=overlapped_query_start_loc,
+        ).transpose(0, 1)[overlap_size:seq_len + overlap_size]
+        if not cp_group.is_last_rank:
+            send_handle.wait()
+        return mixed_qkv
