+    def send_mamba_state_slice(
+        self,
+        req: TransferInfo,
+        prefill_mamba_index: list[int],
+        dst_state_data_ptrs: list[int],
+        dst_tp_rank: int,
+        dst_attn_tp_size: int,
+    ):
+        """
+        Sends Mamba state slices from this Prefill rank to a target Decode rank,
+        supporting generic M-to-N TP size configurations.
+        """
+        assert len(prefill_mamba_index) == 1, "Mamba should have single state index"
+
+        # Extract configuration
+        local_tp_rank_in_group = self.kv_args.engine_rank % self.attn_tp_size
+        dst_tp_rank_in_group = dst_tp_rank % dst_attn_tp_size
+        num_state_heads = self.kv_args.state_head_num
+
+        # Calculate head distribution
+        src_heads_per_rank = num_state_heads // self.attn_tp_size
+        dst_heads_per_rank = num_state_heads // dst_attn_tp_size
+
+        # Determine slicing parameters based on TP configuration
+        if self.attn_tp_size > dst_attn_tp_size:
+            # Send cache from multiple prefill instances to 1 decode instance
+            src_head_start_offset = 0
+            num_heads_to_send = src_heads_per_rank
+            dst_head_start_offset = local_tp_rank_in_group * src_heads_per_rank
+        else:
+            # Send cache from 1 prefill instance to multiple decode instances
+            src_head_start_offset = (
+                dst_tp_rank_in_group * dst_heads_per_rank
+            ) % src_heads_per_rank
+            num_heads_to_send = dst_heads_per_rank
+            dst_head_start_offset = 0
+
+        transfer_blocks = []
+        src_state_data_ptrs = self.kv_args.state_data_ptrs
+        for i, (src_state_ptr, dst_state_ptr) in enumerate(zip(src_state_data_ptrs, dst_state_data_ptrs)):
+            src_length = self.kv_args.state_item_lens[i]
+            bytes_per_head_slice_to_send = src_length // src_heads_per_rank
+            # Calculate precise byte offset and length for the sub-slice
+            src_head_slice_offset = src_head_start_offset * bytes_per_head_slice_to_send
+            dst_head_slice_offset = dst_head_start_offset * bytes_per_head_slice_to_send
+            dst_length = num_heads_to_send * bytes_per_head_slice_to_send
+            # Calculate final src and dst addresses by applying head-slice offsets
+            src_slice_addr = src_state_ptr + int(prefill_mamba_index[0]) * src_length + src_head_slice_offset
+            dst_slice_addr = dst_state_ptr + int(req.dst_state_indices[0]) * dst_length + dst_head_slice_offset
+            transfer_blocks.append((src_slice_addr, dst_slice_addr, dst_length))
+
+        return self._transfer_data(req.mooncake_session_id, transfer_blocks)
+
     def sync_status_to_decode_endpoint(
