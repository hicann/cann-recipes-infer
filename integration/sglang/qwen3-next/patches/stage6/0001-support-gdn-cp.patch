+    def init_cp_metadata(self):
+        """
+        Adjusts `query_start_loc` according to split sizes along the sequence length.
+        Required because forward metadata is generated before input sequence is split
+        when context parallelism is enabled.
+        Assumes that queries are splitted uniformly between devices:
+        Context: [A0, A1, A2, A3, B0, B1, B2]
+        Dev 0: [A0, A1, B0, B1]
+        Dev 1: [A2, A3, B2]
+        """
+        def get_split_sizes(seq_len, sections):
+            base_size = seq_len // sections
+            remainder = seq_len % sections
+            sizes = [base_size + 1] * remainder + [base_size] * (sections - remainder)
+            return sizes
+
+        cu_seqlens = self.forward_metadata.query_start_loc.clone()
+        if self.enable_context_parallel_gdn:
+            cp_size = get_context_model_parallel_world_size()
+            cp_rank = get_context_model_parallel_rank()
+            for i, (s, e) in enumerate(zip(cu_seqlens[:-1], cu_seqlens[1:])):
+                cu_seqlens[i+1] = cu_seqlens[i] + get_split_sizes(seq_len=e-s, sections=cp_size)[cp_rank]
+        self.cu_seqlens = cu_seqlens
+
