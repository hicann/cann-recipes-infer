+                            overlap_start = query_start_loc[i + 1] - overlap_size
+                            dist.send(mixed_qkv[overlap_start:overlap_start + overlap_size].transpose(0, 1).contiguous(),
+                                      dst=cp_group.next_rank)
+
+                mixed_qkv = causal_conv1d_fn_npu(
