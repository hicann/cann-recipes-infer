+# ---------------------------------------------------------------------------
+# NPU + KT downstream patch:
+# ---------------------------------------------------------------------------
+# 在我们的 NPU docker 里 ``triton 3.7`` 与 ``triton-ascend 3.2`` 版本错配，
+# 任何 ``@triton.jit`` kernel 在调用时都会抛 ``0 active drivers ([])``。基线
+# 已经为 attention backend == "ascend" 在 ``support_triton`` 里把 ascend 标
+# 成 False，但本文件里 ``write_multi_cache_indices`` / ``get_last_loc`` 等公
+# 共函数并没全部去判这个旗子（应该是 oversight，因为 baseline 8 卡机器上
+# triton 装得是好的），到了 NPU 单卡 prefill 就会炸。
+#
+# 这里加一次性 driver 探测；探到不可用，则把所有调用点切到 torch 等价路径
+# （纯 PyTorch、bs=1/2 单卡场景性能可接受，且数值完全等价）。该探测和
+# ``hardware_backend/npu/allocator_npu.py`` 里那个用的是同样的逻辑，保持一致。
+def _detect_triton_driver_available() -> bool:
+    try:
+        # triton ships no type stubs; this is the availability probe whose failure falls back to the
+        # torch-equivalent path when triton x ascend is unusable, hence the type: ignore.
+        from triton.runtime.driver import driver as _triton_driver  # type: ignore
+
+        _ = _triton_driver.active
+        return True
+    except Exception:
+        return False
+
+
+_TRITON_DRIVER_AVAILABLE = _detect_triton_driver_available()
+
+
+def _write_req_to_token_pool_torch(
+    req_to_token_ptr: torch.Tensor,
+    req_pool_indices: torch.Tensor,
+    prefix_tensors: list[torch.Tensor],
+    pre_lens: torch.Tensor,
+    seq_lens: torch.Tensor,
+    extend_lens: torch.Tensor,
+    out_cache_loc: torch.Tensor,
+) -> None:
+    """Pure-PyTorch equivalent of ``write_req_to_token_pool_triton`` for NPU.
+
+    Mirrors the Triton kernel: for batch ``i`` copy ``prefix_tensors[i][:pre_len]``
+    into ``req_to_token_ptr[req_pool_index, :pre_len]`` and the extend slice of
+    ``out_cache_loc`` into ``req_to_token_ptr[req_pool_index, pre_len:seq_len]``.
+    """
+    bs = req_pool_indices.shape[0]
+    if bs == 0:
+        return
+    cumsum_start = 0
+    for i in range(bs):
+        req_idx = int(req_pool_indices[i].item())
+        pre_len = int(pre_lens[i].item())
+        seq_len = int(seq_lens[i].item())
+        extend_len = int(extend_lens[i].item())
+        if pre_len > 0:
+            req_to_token_ptr[req_idx, :pre_len] = prefix_tensors[i][:pre_len].to(
+                req_to_token_ptr.dtype
+            )
+        write_len = seq_len - pre_len
+        if write_len > 0:
+            req_to_token_ptr[req_idx, pre_len:seq_len] = out_cache_loc[
+                cumsum_start : cumsum_start + write_len
+            ].to(req_to_token_ptr.dtype)
+        cumsum_start += extend_len
+
+
+def _write_req_to_token_pool_only_alloc_size_torch(
+    req_to_token_ptr: torch.Tensor,
+    req_pool_indices: torch.Tensor,
+    prefix_tensors: list[torch.Tensor],
+    pre_lens: torch.Tensor,
+    seq_lens: torch.Tensor,
+    alloc_lens: torch.Tensor,
+    out_cache_loc: torch.Tensor,
+) -> None:
+    bs = req_pool_indices.shape[0]
+    if bs == 0:
+        return
+    cumsum_start = 0
+    for i in range(bs):
+        req_idx = int(req_pool_indices[i].item())
+        pre_len = int(pre_lens[i].item())
+        seq_len = int(seq_lens[i].item())
+        alloc_len = int(alloc_lens[i].item())
+        alloc_offset = seq_len - alloc_len
+        if pre_len > 0:
+            req_to_token_ptr[req_idx, :pre_len] = prefix_tensors[i][:pre_len].to(
+                req_to_token_ptr.dtype
+            )
+        if alloc_len > 0:
+            req_to_token_ptr[
+                req_idx, alloc_offset : alloc_offset + alloc_len
+            ] = out_cache_loc[cumsum_start : cumsum_start + alloc_len].to(
+                req_to_token_ptr.dtype
+            )
+        cumsum_start += alloc_len
+
+
