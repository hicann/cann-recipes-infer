+// MXFP4 (OCP microscaling FP4): E2M1 LUT scaled ×2 so the ×0.5 folds into the
+// E8M0 "half" scale below. kvalues_mxfp4[n] * GGML_E8M0_TO_FP32_HALF(e) equals the
+// model's FP4_TABLE[n] * 2^(e-127) bit-for-bit (see DeepSeek-V4-Flash inference/convert.py).
+static const int8_t kvalues_mxfp4[16] = {0, 1, 2, 3, 4, 6, 8, 12, 0, -1, -2, -3, -4, -6, -8, -12};
+
+// E8M0 group exponent -> fp32 * 0.5 (folds the ×0.5 for kvalues_mxfp4 above).
+// Matches upstream ggml_e8m0_to_fp32_half.
+static inline float ggml_e8m0_to_fp32_half(uint8_t x) {
+    uint32_t bits;
+    if (x < 2) {
+        bits = (uint32_t)0x00200000 << x;
+    } else {
+        bits = (uint32_t)(x - 1) << 23;
+    }
+    float result;
+    memcpy(&result, &bits, sizeof(float));
+    return result;
+}
+#define GGML_E8M0_TO_FP32_HALF(x) ggml_e8m0_to_fp32_half(x)
+
+void dequantize_row_mxfp4(const block_mxfp4 * restrict x, float * restrict y, int64_t k) {
+    assert(k % QK_MXFP4 == 0);
+    const int64_t nb = k / QK_MXFP4;
+
+    for (int i = 0; i < nb; i++) {
+        const uint8_t * qs = x[i].qs;
+        const float d = GGML_E8M0_TO_FP32_HALF(x[i].e);
+        for (int j = 0; j < QK_MXFP4/2; ++j) {
+            y[j+         0] = d * kvalues_mxfp4[qs[j] & 0xf];
+            y[j+QK_MXFP4/2] = d * kvalues_mxfp4[qs[j] >>  4];
+        }
+        y  += QK_MXFP4;
+        qs += QK_MXFP4/2;
+    }
+}
+
