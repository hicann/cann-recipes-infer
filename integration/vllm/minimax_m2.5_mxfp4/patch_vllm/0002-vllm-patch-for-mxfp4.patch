From b085134906079052edd1bdb5dd43c87897cac73a Mon Sep 17 00:00:00 2001
From: root <root@liteserver-hps-5c19-00001.novalocal>
Date: Mon, 23 Mar 2026 07:14:49 +0000
Subject: [PATCH 2/7] Add NPU-safe MXFP4 dequant and activation QDQ fallbacks.

This prevents CUDA-only quark kernels from crashing startup on Ascend by using software fallback paths for dequantization and QDQ emulation.
---
 .../layers/quantization/utils/mxfp4_utils.py  | 44 +++++++++++++++----
 1 file changed, 35 insertions(+), 9 deletions(-)

diff --git a/vllm/model_executor/layers/quantization/utils/mxfp4_utils.py b/vllm/model_executor/layers/quantization/utils/mxfp4_utils.py
index e9ecf05..bd078fa 100644
--- a/vllm/model_executor/layers/quantization/utils/mxfp4_utils.py
+++ b/vllm/model_executor/layers/quantization/utils/mxfp4_utils.py
@@ -3,6 +3,8 @@
 from collections.abc import Callable
 from typing import Any
 
+import os
+
 import torch
 
 from vllm.logger import init_logger
@@ -116,16 +118,19 @@ def get_padding_alignment():
     )
 
 
-def _dequant_mxfp4(
-    x: torch.Tensor, scale: torch.Tensor, float_dtype: torch.dtype
-) -> torch.Tensor:
+def _dequant_mxfp4(x: torch.Tensor, scale: torch.Tensor,
+                   float_dtype: torch.dtype = torch.float16) -> torch.Tensor:
+    # amd-quark dq_mxfp4 kernel is CUDA/ROCm-only. On NPU, use python fallback
+    # to avoid hard failure during weight loading.
+    if not (current_platform.is_cuda() or current_platform.is_rocm()):
+        return _dequant_mxfp4_fake(x, scale, float_dtype)
+
     try:
         from quark.torch.kernel import mx
     except ImportError as err:
         raise ImportError(
-            "The package `amd-quark` is required to use "
-            "MX-FP4 models. Please install it with `pip install "
-            "amd-quark`."
+            "The package amd-quark is required to use "
+            "MX-FP4 models. Please install it with pip install amd-quark."
         ) from err
 
     return mx.dq_mxfp4(x, scale, float_dtype)
@@ -142,13 +147,34 @@ def _dequant_mxfp4_fake(
 def _quant_dequant_mxfp4(
     x: torch.Tensor, scale_calculation_mode: str = "even"
 ) -> torch.Tensor:
+    if os.getenv("VLLM_MXFP4_SKIP_ACT_QDQ", "0") == "1":
+        return x
+
+    # amd-quark qdq_mxfp4 kernel is CUDA/ROCm-only. On NPU, use a
+    # lightweight software QDQ fallback to preserve quantization simulation.
+    if not (current_platform.is_cuda() or current_platform.is_rocm()):
+        x_fp = x.to(torch.float32)
+        block = 32
+        last = x_fp.shape[-1]
+        pad = (block - (last % block)) % block
+        if pad:
+            x_fp = torch.nn.functional.pad(x_fp, (0, pad))
+        x_view = x_fp.view(*x_fp.shape[:-1], -1, block)
+        max_abs = x_view.abs().amax(dim=-1, keepdim=True)
+        scale = (max_abs / 7.0).clamp_min(1e-8)
+        q = torch.clamp(torch.round(x_view / scale), -8, 7)
+        dq = q * scale
+        dq = dq.reshape(*x_fp.shape[:-1], -1)
+        if pad:
+            dq = dq[..., :last]
+        return dq.to(x.dtype)
+
     try:
         from quark.torch.kernel import mx
     except ImportError as err:
         raise ImportError(
-            "The package `amd-quark` is required to use "
-            "MX-FP4 models. Please install it with `pip install "
-            "amd-quark`."
+            "The package amd-quark is required to use "
+            "MX-FP4 models. Please install it with pip install amd-quark."
         ) from err
 
     return mx.qdq_mxfp4(x, scale_calculation_mode)
-- 
